# SECTION 11 — AUDIO GENERATOR
# ═══════════════════════════════════════════════════════════════════════════════

class AudioGenerator:
    def __init__(self, config: Config):
        self.config = config
        self.temp_dir = os.path.join(config.output_dir, "temp_audio")
        os.makedirs(self.temp_dir, exist_ok=True)

    def generate(self, total_duration: float, winner_name: str,
                 countdown_dur: float,
                 death_times: List[float],
                 challenge_times: List[float]) -> Optional[str]:
        sr = 44100
        total_samples = int(total_duration * sr)
        audio = np.zeros(total_samples, dtype=np.float64)
        rng_audio = np.random.default_rng(hash(self.config.seed) % (2**31))

        # Countdown beeps
        for bt in [0.0, 1.0, 2.0]:
            self._add_beep(audio, sr, bt, freq=330, dur_ms=120, vol=0.5)
        go_time = countdown_dur - 0.15
        self._add_beep(audio, sr, go_time, freq=660, dur_ms=250, vol=0.6)
        self._add_beep(audio, sr, go_time, freq=830, dur_ms=250, vol=0.35)

        # Racing beat
        race_start = int(countdown_dur * sr)
        race_end = int((total_duration - 6.0) * sr)
        race_end = min(race_end, total_samples)
        bpm = 148
        beat_samples = int(60.0 / bpm * sr)
        half_beat = beat_samples // 2

        kick_len = int(0.10 * sr)
        kick_t = np.arange(kick_len, dtype=np.float64) / sr
        kick = np.sin(2 * np.pi * 65 * kick_t) * np.exp(-kick_t * 35) * 0.4

        snare_len = int(0.05 * sr)
        snare_t = np.arange(snare_len, dtype=np.float64) / sr
        snare = rng_audio.standard_normal(snare_len) * np.exp(-snare_t * 45) * 0.15

        hh_len = int(0.02 * sr)
        hh = rng_audio.standard_normal(hh_len) * np.exp(
        -np.arange(hh_len, dtype=np.float64) / sr * 90) * 0.04

        bass_freqs = [131.0, 165.0, 196.0, 131.0]
        bass_dur = int(beat_samples * 0.75)
        bass_t_arr = np.arange(bass_dur, dtype=np.float64) / sr
        bass_env = np.exp(-bass_t_arr * 7)

        mel_notes = [523, 659, 784, 659, 523, 587, 659, 523]
        mel_dur = half_beat
        mel_t_arr = np.arange(mel_dur, dtype=np.float64) / sr
        mel_fade = max(1, mel_dur // 8)
        mel_env = np.ones(mel_dur, dtype=np.float64)
        mel_env[:mel_fade] = np.linspace(0, 1, mel_fade)
        mel_env[-mel_fade:] = np.linspace(1, 0, mel_fade)
        mel_env *= np.exp(-mel_t_arr * 5)

        num_beats = (race_end - race_start) // beat_samples + 1
        mel_idx = 0

        for i_beat in range(num_beats):
            pos = race_start + i_beat * beat_samples
            self._safe_add(audio, pos, kick, total_samples)
            if i_beat % 4 in (1, 3):
                self._safe_add(audio, pos, snare, total_samples)
            for off in (0, half_beat):
                self._safe_add(audio, pos + off, hh, total_samples)
            note_freq = bass_freqs[i_beat % len(bass_freqs)]
            bass_wave = np.sin(2 * np.pi * note_freq * bass_t_arr) * bass_env * 0.12
            self._safe_add(audio, pos, bass_wave, total_samples)
            for m_off in (0, half_beat):
                mel_freq = mel_notes[mel_idx % len(mel_notes)]
                mel_wave = (np.sin(2 * np.pi * mel_freq * mel_t_arr) +
                            np.sin(2 * np.pi * mel_freq * 3 * mel_t_arr) * 0.25
                            ) * mel_env * 0.055
                self._safe_add(audio, pos + m_off, mel_wave, total_samples)
                mel_idx += 1

        # Death SFX
        death_thud_len = int(0.08 * sr)
        death_thud_t = np.arange(death_thud_len, dtype=np.float64) / sr
        death_thud = np.sin(2 * np.pi * 45 * death_thud_t) * np.exp(-death_thud_t * 25) * 0.3

        pop_len = int(0.06 * sr)
        pop_t = np.arange(pop_len, dtype=np.float64) / sr
        pop_freq_sweep = 800 - pop_t * 8000
        pop_phase = np.cumsum(pop_freq_sweep / sr) * 2 * np.pi
        pop_sound = np.sin(pop_phase) * np.exp(-pop_t * 40) * 0.15

        for dt_time in death_times:
            sample_pos = int(dt_time * sr)
            self._safe_add(audio, sample_pos, death_thud, total_samples)
            self._safe_add(audio, sample_pos + int(0.02 * sr), pop_sound, total_samples)

        # Challenge announcement sounds
        challenge_fanfare_len = int(0.3 * sr)
        challenge_fanfare_t = np.arange(challenge_fanfare_len, dtype=np.float64) / sr
        challenge_fanfare = (
            np.sin(2 * np.pi * 440 * challenge_fanfare_t) * 0.15 +
            np.sin(2 * np.pi * 554 * challenge_fanfare_t) * 0.12 +
            np.sin(2 * np.pi * 659 * challenge_fanfare_t) * 0.10
        )
        fanfare_env = np.ones(challenge_fanfare_len, dtype=np.float64)
        fanfare_fade = max(1, challenge_fanfare_len // 4)
        fanfare_env[-fanfare_fade:] = np.linspace(1, 0, fanfare_fade)
        challenge_fanfare *= fanfare_env

        for ct_time in challenge_times:
            sample_pos = int(ct_time * sr)
            self._safe_add(audio, sample_pos, challenge_fanfare, total_samples)

        # Rising tension last 25%
        tension_start = race_start + int((race_end - race_start) * 0.75)
        tension_len = race_end - tension_start
        if tension_len > 0:
            ten_t = np.arange(tension_len, dtype=np.float64) / sr
            progress_t = np.linspace(0.0, 1.0, tension_len)
            freq_sweep = 200.0 + progress_t * 800.0
            phase_sweep = np.cumsum(freq_sweep / sr) * 2 * np.pi
            tension_wave = np.sin(phase_sweep) * progress_t * 0.04
            self._safe_add(audio, tension_start, tension_wave, total_samples)

        # Winner celebration
        celeb_start = race_end
        celeb_len = total_samples - celeb_start
        if celeb_len > 0:
            celeb_t = np.arange(celeb_len, dtype=np.float64) / sr
            victory = (
                np.sin(2 * np.pi * 261.63 * celeb_t) * 0.18 +
                np.sin(2 * np.pi * 329.63 * celeb_t) * 0.15 +
                np.sin(2 * np.pi * 392.00 * celeb_t) * 0.13 +
                np.sin(2 * np.pi * 493.88 * celeb_t) * 0.10
            )
            chord_env = np.exp(-celeb_t * 0.5)
            self._safe_add(audio, celeb_start, victory * chord_env, total_samples)

            sparkle_offsets = [0.05, 0.25, 0.55, 0.85, 1.15, 1.45]
            sparkle_freqs_list = [
                (1200, 800), (1000, 600), (1100, 700),
                (1300, 900), (1150, 750), (1050, 650),
            ]
            spark_dur = int(0.15 * sr)
            for sp_off, (sf1, sf2) in zip(sparkle_offsets, sparkle_freqs_list):
                sp_start = celeb_start + int(sp_off * sr)
                sp_actual = min(spark_dur, total_samples - sp_start)
                if sp_actual > 0:
                    sp_t = np.arange(sp_actual, dtype=np.float64) / sr
                    sp_prog = np.linspace(0, 1, sp_actual)
                    sp_freq = sf1 - sp_prog * (sf1 - sf2)
                    sp_phase = np.cumsum(sp_freq / sr) * 2 * np.pi
                    sp_env = np.exp(-sp_t * 12)
                    self._safe_add(audio, sp_start,
                                   np.sin(sp_phase) * sp_env * 0.10, total_samples)

            cheer_len = min(celeb_len, int(3.0 * sr))
            cheer_noise = rng_audio.standard_normal(cheer_len)
            cheer_t_arr = np.arange(cheer_len, dtype=np.float64) / sr
            attack = min(int(0.1 * sr), cheer_len)
            cheer_env = np.exp(-cheer_t_arr * 0.6)
            if attack > 0:
                cheer_env[:attack] = np.linspace(0, 1, attack)
            self._safe_add(audio, celeb_start,
                           cheer_noise * cheer_env * 0.05, total_samples)

        # Winner TTS
        tts_path = self._generate_tts(winner_name)
        if tts_path and os.path.exists(tts_path):
            try:
                tts_seg = AudioSegment.from_file(tts_path)
                tts_samples = np.array(tts_seg.get_array_of_samples(),
                                       dtype=np.float64)
                if tts_seg.channels == 2:
                    tts_samples = tts_samples[::2]
                tts_samples = tts_samples / 32768.0 * 0.75

                if tts_seg.frame_rate != sr:
                    ratio_tts = sr / tts_seg.frame_rate
                    new_len_tts = int(len(tts_samples) * ratio_tts)
                    tts_samples = np.interp(
                        np.linspace(0, len(tts_samples) - 1, new_len_tts),
                        np.arange(len(tts_samples)), tts_samples)

                tts_start = celeb_start + int(0.8 * sr)
                tts_end = min(tts_start + len(tts_samples), total_samples)
                actual_tts = tts_end - tts_start
                if actual_tts > 0:
                    audio[tts_start:tts_end] += tts_samples[:actual_tts]
            except Exception as e:
                print(f"⚠️ TTS load failed: {e}")

        # Normalize
        max_val = np.max(np.abs(audio))
        if max_val > 0:
            audio = audio / max_val * 0.80

        audio_int16 = (audio * 32767).astype(np.int16)

        audio_path = os.path.join(self.temp_dir, "battle_audio.wav")
        with wave_mod.open(audio_path, 'w') as wf:
            wf.setnchannels(1)
            wf.setsampwidth(2)
            wf.setframerate(sr)
            wf.writeframes(audio_int16.tobytes())

        print(f"✅ Audio generated: {audio_path}")
        return audio_path

    def _add_beep(self, audio: np.ndarray, sr: int, time_s: float,
                  freq: float = 440, dur_ms: int = 150, vol: float = 0.5):
        n = int(sr * dur_ms / 1000.0)
        t = np.arange(n, dtype=np.float64) / sr
        wave = np.sin(2 * np.pi * freq * t) * vol
        fade = max(1, int(n * 0.1))
        env = np.ones(n, dtype=np.float64)
        env[:fade] = np.linspace(0, 1, fade)
        env[-fade:] = np.linspace(1, 0, fade)
        wave *= env
        self._safe_add(audio, int(time_s * sr), wave, len(audio))

    @staticmethod
    def _safe_add(audio: np.ndarray, start: int, data: np.ndarray, total: int):
        if start < 0:
            return
        end = min(start + len(data), total)
        actual = end - start
        if actual > 0:
            audio[start:end] += data[:actual]

    def _generate_tts(self, name: str) -> Optional[str]:
        try:
            tts = gTTS(text=f"{name} wins! Last ball standing!", lang='en',
                       slow=False)
            path = os.path.join(self.temp_dir, "winner_tts.mp3")
            tts.save(path)
            return path
        except Exception as e:
            print(f"⚠️ TTS failed: {e}")
            return None

    def cleanup(self):
        for f in glob.glob(os.path.join(self.temp_dir, "*")):
            try:
                os.remove(f)
            except OSError:
                pass

print("✅ Audio generator ready.")


