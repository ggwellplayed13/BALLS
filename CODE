# SECTION 12 — GAME ORCHESTRATOR (MASTER CLASS)
# ═══════════════════════════════════════════════════════════════════════════════

class BallBattleRoyale:
    def __init__(self, config: Optional[Config] = None):
        self.config = config or Config()
        self.rng = random.Random(self.config.seed)
        print(f"🎲 Seed: {self.config.seed}")

    def run(self) -> str:
        config = self.config
        fps = config.fps
        total_frames = int(config.duration * fps)
        countdown_dur = 3.5
        countdown_frames = int(countdown_dur * fps)
        winner_dur = 6.0

        print(f"\n{'=' * 60}")
        print(f"  🔴 BRAINROT BATTLE ROYALE")
        print(f"  Duration: {config.duration}s | FPS: {fps} | Frames: {total_frames}")
        print(f"{'=' * 60}\n")

        # ── Download character images ──
        char_pool = list(BRAINROT_CHARACTERS)
        self.rng.shuffle(char_pool)
        while len(char_pool) < config.num_balls:
            extra = list(BRAINROT_CHARACTERS)
            self.rng.shuffle(extra)
            char_pool.extend(extra)
        assigned_chars = char_pool[:config.num_balls]

        all_used_chars = list({c["name"]: c for c in assigned_chars}.values())
        character_images = download_character_images(
            all_used_chars, config.image_cache_dir, icon_size=64)

        # ── Select challenges ──
        available_categories: Set[str] = set()
        selected_challenges: List[Dict] = []
        pool = list(ALL_CHALLENGES)
        self.rng.shuffle(pool)

        for ch in pool:
            if ch["category"] not in available_categories:
                selected_challenges.append(ch)
                available_categories.add(ch["category"])
            if len(selected_challenges) >= config.challenges_per_game:
                break

        if len(selected_challenges) < config.challenges_per_game:
            remaining = [c for c in pool if c not in selected_challenges]
            for c in remaining:
                selected_challenges.append(c)
                if len(selected_challenges) >= config.challenges_per_game:
                    break

        self.rng.shuffle(selected_challenges)

        print("🎯 Selected challenges:")
        for i, ch in enumerate(selected_challenges):
            print(f"   {i + 1}. {ch['emoji']} {ch['name']}")

        # ── Create balls ──
        print(f"\n🔵 Creating {config.num_balls} brainrot balls...")
        colors = generate_vibrant_colors(config.num_balls, self.rng)

        physics = PhysicsEngine(config, self.rng)
        arena_init = physics.get_arena(countdown_dur)
        ax1, ay1, ax2, ay2 = arena_init

        balls: List[Ball] = []
        cols, rows = 10, 10
        for i in range(config.num_balls):
            col = i % cols
            row = i // cols
            margin = config.ball_radius * 2.5
            x = ax1 + margin + col * ((ax2 - ax1 - 2 * margin) / max(1, cols - 1))
            y = ay1 + margin + row * ((ay2 - ay1 - 2 * margin) / max(1, rows - 1))
            balls.append(Ball(i, x, y, config.ball_radius, colors[i],
                              self.rng, assigned_chars[i]))

        # ── Init systems ──
        hazards = HazardManager(config, self.rng)
        renderer = Renderer(config, character_images)

        # ── Pre-simulate ──
        print("⚙️ Pre-simulating game...")

        frame_data: List[Dict] = []
        winner: Optional[Ball] = None
        forced_kill_timer = 0
        death_times: List[float] = []
        challenge_times: List[float] = []

        # Schedule challenges
        race_duration = config.duration - countdown_dur - winner_dur
        interval = race_duration / max(1, len(selected_challenges))
        challenge_schedule: List[Tuple[float, int]] = []
        for idx_s, ch in enumerate(selected_challenges):
            act_time = countdown_dur + interval * idx_s + self.rng.uniform(1, 3)
            act_time = min(act_time, config.duration - winner_dur - 2)
            challenge_schedule.append((act_time, idx_s))
        challenge_schedule.sort(key=lambda x: x[0])
        next_challenge_ptr = 0
        current_challenge_index = 0

        original_bounce = config.bounce_damping
        original_margin = config.arena_margin_end

        for frame in range(total_frames):
            t = frame / fps

            if t < countdown_dur:
                phase = "countdown"
            elif winner is not None:
                phase = "winner"
            else:
                phase = "racing"

            arena = physics.get_arena(t)

            if phase == "racing":
                # ── Activate challenges ──
                while (next_challenge_ptr < len(challenge_schedule) and
                       t >= challenge_schedule[next_challenge_ptr][0]):
                    sched_time, sched_idx = challenge_schedule[next_challenge_ptr]
                    ch = selected_challenges[sched_idx]
                    current_challenge_index = sched_idx + 1

                    try:
                        ch["apply"](
                            balls=balls, arena=arena, hazards=hazards,
                            rng=self.rng, config=config,
                            frame=frame, renderer=renderer,
                        )
                    except Exception as e:
                        print(f"⚠️ Challenge '{ch['name']}' error: {e}")

                    renderer.set_challenge_banner(frame, ch["name"], ch["emoji"])
                    renderer.add_event_text(frame, f"{ch['emoji']} {ch['name']}!", 60)
                    renderer.trigger_screen_shake(8.0)
                    challenge_times.append(t)
                    print(f"  ⚡ {ch['emoji']} {ch['name']} at t={t:.1f}s")
                    next_challenge_ptr += 1

                # ── Update hazards ──
                hazards.update(t, frame, arena)

                # ── Update physics ──
                physics.update_balls(balls, arena, hazards, frame)

                # ── Check deaths (NATURAL — from visible hazards) ──
                forced_kill_timer += 1
                for ball in [b for b in balls if b.alive]:
                    if hazards.check_ball_death(ball, frame, arena):
                        ball.alive = False
                        ball.death_frame = frame
                        renderer.add_death_particles(ball.x, ball.y, ball.color, frame)
                        renderer.add_bubble_explosion(ball.x, ball.y, ball.color, frame)
                        renderer.add_elimination(frame, ball.name, ball.color)
                        death_times.append(t)
                        forced_kill_timer = 0

                # ── Pacing: only force kills if WAY too many alive late game ──
                alive_now = sum(1 for b in balls if b.alive)
                race_progress = max(0.001, (t - countdown_dur) / race_duration)

                # Soft pacing: if we're past 70% and still >30 alive, add hazards
                if race_progress > 0.7 and alive_now > 30 and forced_kill_timer > fps * 4:
                    ax1_a, ay1_a, ax2_a, ay2_a = arena
                    angle_f = self.rng.uniform(0, 2 * math.pi)
                    hazards.fireballs.append(Fireball(
                        x=(ax1_a + ax2_a) / 2, y=(ay1_a + ay2_a) / 2,
                        vx=math.cos(angle_f) * 5, vy=math.sin(angle_f) * 5,
                        radius=20, lifetime=15))
                    forced_kill_timer = 0

                # Hard pacing: only if >90% through and >40 alive; use fireball not direct kill
                if race_progress > 0.9 and alive_now > 40 and forced_kill_timer > fps * 5:
                    ax1_h, ay1_h, ax2_h, ay2_h = arena
                    angle_h = self.rng.uniform(0, 2 * math.pi)
                    hazards.fireballs.append(Fireball(
                        x=(ax1_h + ax2_h) / 2, y=(ay1_h + ay2_h) / 2,
                        vx=math.cos(angle_h) * 5, vy=math.sin(angle_h) * 5,
                        radius=22, lifetime=15))
                    forced_kill_timer = 0

                # ── Check winner ──
                alive_now = sum(1 for b in balls if b.alive)
                if alive_now <= 1 and winner is None:
                    alive_list = [b for b in balls if b.alive]
                    if alive_list:
                        winner = alive_list[0]
                    else:
                        last_dead = max(balls, key=lambda b: b.death_frame)
                        last_dead.alive = True
                        winner = last_dead
                    print(f"🏆 WINNER: {winner.emoji} {winner.name} at t={t:.1f}s")

                alive_count = sum(1 for b in balls if b.alive)
            elif phase == "countdown":
                alive_count = config.num_balls
            else:
                alive_count = 1

            # ── Store snapshot ──
            snapshot = {
                "t": t, "frame": frame, "phase": phase,
                "arena": arena, "alive_count": alive_count,
                "challenge_index": current_challenge_index,
                "ball_states": [],
                "hazard_state": _snapshot_hazards(hazards),
            }
            for b in balls:
                snapshot["ball_states"].append({
                    "id": b.id, "x": b.x, "y": b.y,
                    "vx": b.vx, "vy": b.vy,
                    "alive": b.alive, "color": b.color,
                    "accent": b.accent, "outline_color": b.outline_color,
                    "trail": list(b.trail),
                    "invincible_timer": b.invincible_timer,
                    "radius": b.radius,
                })
            frame_data.append(snapshot)

            if frame % (fps * 5) == 0:
                print(f"  Frame {frame}/{total_frames} | t={t:.1f}s | alive={alive_count}")

        if winner is None:
            alive_list = [b for b in balls if b.alive]
            if alive_list:
                winner = alive_list[0]
            else:
                winner = max(balls, key=lambda b: b.death_frame)
                winner.alive = True
            print(f"🏆 WINNER (time limit): {winner.emoji} {winner.name}")

        print(f"\n✅ Simulation: {len(frame_data)} frames, {len(death_times)} deaths")
        gc.collect()

        config.bounce_damping = original_bounce
        config.arena_margin_end = original_margin

        # ── Audio ──
        print("🔊 Generating audio...")
        audio_gen = AudioGenerator(config)
        audio_path = audio_gen.generate(
            config.duration, winner.name, countdown_dur,
            death_times, challenge_times)

        # ── Encode video ──
        print("🎬 Encoding video...")

        frame_cache: Dict[int, np.ndarray] = {}
        cache_limit = 3

        def make_frame(t_sec: float) -> np.ndarray:
            f_idx = min(int(t_sec * fps), len(frame_data) - 1)

            if f_idx in frame_cache:
                return frame_cache[f_idx]

            snap = frame_data[f_idx]

            for i_b, bs in enumerate(snap["ball_states"]):
                balls[i_b].x = bs["x"]
                balls[i_b].y = bs["y"]
                balls[i_b].vx = bs["vx"]
                balls[i_b].vy = bs["vy"]
                balls[i_b].alive = bs["alive"]
                balls[i_b].trail = bs["trail"]
                balls[i_b].invincible_timer = bs["invincible_timer"]
                balls[i_b].radius = bs["radius"]

            _restore_hazards(hazards, snap["hazard_state"])

            rendered = renderer.render_frame(
                snap["t"], snap["frame"], balls,
                snap["arena"], hazards,
                snap["alive_count"], config.num_balls,
                winner if snap["phase"] == "winner" else None,
                snap["phase"],
                selected_challenges,
                snap["challenge_index"],
            )

            frame_cache[f_idx] = rendered
            if len(frame_cache) > cache_limit:
                oldest = min(frame_cache.keys())
                del frame_cache[oldest]

            if f_idx % 100 == 0 and f_idx > 0:
                gc.collect()

            return rendered

        timestamp = time.strftime("%Y%m%d_%H%M%S")
        rand_suffix = ''.join(random.choices('abcdefghijklmnopqrstuvwxyz0123456789', k=4))
        output_path = os.path.join(config.output_dir,
                                    f"brainrot_battle_{timestamp}_{rand_suffix}.mp4")

        video_clip = VideoClip(make_frame, duration=config.duration).set_fps(fps)

        if audio_path and os.path.exists(audio_path):
            try:
                audio_clip = AudioFileClip(audio_path)
                if audio_clip.duration > config.duration:
                    audio_clip = audio_clip.subclip(0, config.duration)
                video_clip = video_clip.set_audio(audio_clip)
                print("✅ Audio attached.")
            except Exception as e:
                print(f"⚠️ Audio attach failed: {e}")

        video_clip.write_videofile(
            output_path, fps=fps, codec="libx264",
            bitrate=config.bitrate, audio_codec="aac",
            logger=None, threads=4)
        video_clip.close()

        file_mb = os.path.getsize(output_path) / (1024 * 1024)
        print(f"\n✅ Video saved: {output_path} ({file_mb:.1f} MB)")

        audio_gen.cleanup()
        frame_cache.clear()
        gc.collect()

        return output_path

    @staticmethod
    def _danger_score(ball: Ball, arena: Tuple[int, int, int, int],
                      hazards: HazardManager) -> float:
        ax1, ay1, ax2, ay2 = arena
        score = 0.0
        score += max(0, 30 - (ball.x - ax1)) * 2
        score += max(0, 30 - (ax2 - ball.x)) * 2
        score += max(0, 30 - (ball.y - ay1)) * 2
        score += max(0, 30 - (ay2 - ball.y)) * 2
        for sp in hazards.spikes:
            d = math.hypot(ball.x - sp.x, ball.y - sp.y)
            if d < sp.radius * 3:
                score += (sp.radius * 3 - d)
        for fb in hazards.fireballs:
            d = math.hypot(ball.x - fb.x, ball.y - fb.y)
            if d < 80:
                score += (80 - d) * 2
        for v in hazards.vortices:
            d = math.hypot(ball.x - v.x, ball.y - v.y)
            if d < v.radius:
                score += (v.radius - d) * 2
        for lz in hazards.lava_zones:
            if lz.thickness > 0:
                if lz.side == "bottom":
                    score += max(0, lz.thickness * 2 - (ay2 - ball.y))
                elif lz.side == "top":
                    score += max(0, lz.thickness * 2 - (ball.y - ay1))
                elif lz.side == "left":
                    score += max(0, lz.thickness * 2 - (ball.x - ax1))
                elif lz.side == "right":
                    score += max(0, lz.thickness * 2 - (ax2 - ball.x))
        return score

