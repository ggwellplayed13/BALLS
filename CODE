# HAZARD SNAPSHOT/RESTORE — guardar y restaurar estado para render correcto
# ──────────────────────────────────────────────────────────────────────────────

def _snapshot_hazards(hazards: HazardManager) -> Dict:
    """Serializa el estado visual de todos los hazards en un dict compacto."""
    return {
        "fireballs": [(fb.x, fb.y, fb.radius, fb.color, list(fb.trail))
                      for fb in hazards.fireballs],
        "spinning_lasers": [(sl.cx, sl.cy, sl.angle, sl.length, sl.thickness,
                             sl.kill_radius, sl.color, sl.arms, sl.warmup_frames)
                            for sl in hazards.spinning_lasers],
        "death_walls": [(dw.side, dw.position, dw.color,
                         dw.warmup_frames, dw.retreating)
                        for dw in hazards.death_walls],
        "shockwaves": [(sw.cx, sw.cy, sw.current_radius, sw.thickness, sw.color)
                       for sw in hazards.shockwaves],
        "meteors": [(m.target_x, m.target_y, m.current_y, m.x, m.radius,
                     m.blast_radius, m.exploded, m.explosion_frame)
                    for m in hazards.meteors],
        "spikes": [(sp.x, sp.y, sp.radius, sp.pulse_phase, sp.warmup_frames)
                   for sp in hazards.spikes],
        "lava_zones": [(lz.side, lz.thickness, lz.warmup_frames)
                       for lz in hazards.lava_zones],
        "vortices": [(v.x, v.y, v.radius, v.rotation, v.kill_radius)
                     for v in hazards.vortices],
    }


def _restore_hazards(hazards: HazardManager, snap: Dict):
    """Restaura el estado de los hazards desde un snapshot para render correcto."""
    hazards.fireballs = [
        Fireball(x=x, y=y, radius=r, vx=0, vy=0, color=c, trail=list(tr))
        for x, y, r, c, tr in snap["fireballs"]]
    hazards.spinning_lasers = [
        SpinningLaser(cx=cx, cy=cy, angle=a, length=ln, thickness=th,
                      kill_radius=kr, color=c, arms=arm, warmup_frames=wf)
        for cx, cy, a, ln, th, kr, c, arm, wf in snap["spinning_lasers"]]
    hazards.death_walls = [
        DeathWall(side=s, position=p, color=c, warmup_frames=wf, retreating=ret)
        for s, p, c, wf, ret in snap["death_walls"]]
    hazards.shockwaves = [
        Shockwave(cx=cx, cy=cy, current_radius=cr, thickness=th, color=c)
        for cx, cy, cr, th, c in snap["shockwaves"]]
    hazards.meteors = [
        Meteor(target_x=tx, target_y=ty, current_y=cy_m, x=mx, radius=r,
               blast_radius=br, exploded=ex, explosion_frame=ef)
        for tx, ty, cy_m, mx, r, br, ex, ef in snap["meteors"]]
    hazards.spikes = [
        Spike(x=x, y=y, radius=r, pulse_phase=pp, warmup_frames=wf)
        for x, y, r, pp, wf in snap["spikes"]]
    hazards.lava_zones = [
        LavaZone(side=s, thickness=th, warmup_frames=wf)
        for s, th, wf in snap["lava_zones"]]
    hazards.vortices = [
        Vortex(x=x, y=y, radius=r, rotation=rot, kill_radius=kr)
        for x, y, r, rot, kr in snap["vortices"]]


