# SECTION 3 — IMAGE DOWNLOADER (descarga imágenes reales de los personajes)
# ═══════════════════════════════════════════════════════════════════════════════

def download_character_images(characters: List[Dict], cache_dir: str,
                              icon_size: int = 64) -> Dict[str, Image.Image]:
    """Intenta descargar un avatar para cada personaje desde DuckDuckGo o
    genera un icono fallback con su emoji/símbolo."""
    os.makedirs(cache_dir, exist_ok=True)
    images: Dict[str, Image.Image] = {}

    print("🖼️ Descargando imágenes de personajes...")
    for i, char in enumerate(characters):
        name = char["name"]
        cache_path = os.path.join(cache_dir,
                                   f"{hashlib.md5(name.encode()).hexdigest()}.png")

        # Si ya la tenemos cacheada, cargarla
        if os.path.exists(cache_path):
            try:
                img = Image.open(cache_path).convert("RGBA")
                img = img.resize((icon_size, icon_size), Image.LANCZOS)
                images[name] = img
                continue
            except Exception:
                pass

        # Intentar descargar
        downloaded = False

        # Try direct img_url first (real character image)
        img_url_direct = char.get("img_url", "")
        if img_url_direct and not downloaded:
            try:
                resp = requests.get(img_url_direct, timeout=8,
                                    headers={"User-Agent": "Mozilla/5.0"})
                if resp.status_code == 200 and len(resp.content) > 500:
                    img = Image.open(io.BytesIO(resp.content)).convert("RGBA")
                    img = img.resize((icon_size, icon_size), Image.LANCZOS)
                    img.save(cache_path)
                    images[name] = img
                    downloaded = True
            except Exception:
                pass

        # Fallback: robohash (generates unique avatar per name)
        if not downloaded:
            try:
                url = f"https://robohash.org/{quote(name)}?size={icon_size}x{icon_size}&set=set4"
                resp = requests.get(url, timeout=5)
                if resp.status_code == 200 and len(resp.content) > 500:
                    img = Image.open(io.BytesIO(resp.content)).convert("RGBA")
                    img = img.resize((icon_size, icon_size), Image.LANCZOS)
                    img.save(cache_path)
                    images[name] = img
                    downloaded = True
            except Exception:
                pass

        if not downloaded:
            # Fallback: generar icono con símbolo
            images[name] = _generate_fallback_icon(char, icon_size)

        if (i + 1) % 20 == 0:
            print(f"   {i + 1}/{len(characters)} procesados...")

    print(f"✅ {len(images)} imágenes de personajes listas.")
    return images


def _generate_fallback_icon(char: Dict, size: int) -> Image.Image:
    """Genera un icono circular con el símbolo del personaje."""
    hue = char.get("hue", random.random())
    r, g, b = [int(c * 255) for c in colorsys.hsv_to_rgb(hue, 0.8, 0.9)]
    img = Image.new("RGBA", (size, size), (0, 0, 0, 0))
    draw = ImageDraw.Draw(img)
    # Círculo de fondo
    draw.ellipse([2, 2, size - 3, size - 3], fill=(r, g, b, 230))
    draw.ellipse([2, 2, size - 3, size - 3], outline=(255, 255, 255, 200), width=2)
    # Símbolo centrado
    font_size = max(8, size // 3)
    font = ImageFont.load_default()
    for path in [
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf",
    ]:
        if os.path.exists(path):
            try:
                font = ImageFont.truetype(path, font_size)
                break
            except Exception:
                continue
    text = char.get("symbol", "?")
    bbox = draw.textbbox((0, 0), text, font=font)
    tw, th = bbox[2] - bbox[0], bbox[3] - bbox[1]
    draw.text(((size - tw) // 2, (size - th) // 2 - 1), text,
              font=font, fill=(255, 255, 255, 255))
    return img


