ALL_CHALLENGES: List[Dict[str, Any]] = []

def _register(name, emoji, category):
    def decorator(func):
        ALL_CHALLENGES.append({"name": name, "emoji": emoji,
                                "category": category, "apply": func})
        return func
    return decorator


@_register("FIREBALL FRENZY", "[FIRE]", "fireball")
def _ch_fireball(balls, arena, hazards, rng, config, **kw):
    ax1, ay1, ax2, ay2 = arena
    for _ in range(rng.randint(2, 4)):
        angle = rng.uniform(0, 2 * math.pi)
        speed = rng.uniform(3.5, 6.0)
        hazards.fireballs.append(Fireball(
            x=rng.uniform(ax1 + 40, ax2 - 40),
            y=rng.uniform(ay1 + 40, ay2 - 40),
            vx=math.cos(angle) * speed,
            vy=math.sin(angle) * speed,
            radius=rng.uniform(14, 22),
            lifetime=rng.uniform(15, 25),
            color=(255, rng.randint(50, 150), 0),
        ))


@_register("SPINNING DEATH RAY", "[ZAP]", "laser")
def _ch_spinning_laser(balls, arena, hazards, rng, config, **kw):
    ax1, ay1, ax2, ay2 = arena
    cx, cy = (ax1 + ax2) / 2, (ay1 + ay2) / 2
    length = min(ax2 - ax1, ay2 - ay1) * 0.30  # reduced from 0.48
    hazards.spinning_lasers.append(SpinningLaser(
        cx=cx + rng.uniform(-30, 30),
        cy=cy + rng.uniform(-30, 30),
        angle=rng.uniform(0, 2 * math.pi),
        length=length,
        speed=rng.uniform(0.015, 0.035),
        thickness=rng.uniform(6, 10),
        kill_radius=rng.uniform(8, 12),
        arms=rng.choice([1, 2]),  # max 2 arms
        warmup_frames=45,
        lifetime_frames=900,
    ))


@_register("DEATH WALL", "[WALL]", "wall")
def _ch_death_wall(balls, arena, hazards, rng, config, **kw):
    sides = rng.sample(["left", "right", "top", "bottom"], rng.randint(1, 2))
    for side in sides:
        hazards.death_walls.append(DeathWall(
            side=side,
            speed=rng.uniform(0.25, 0.55),
            max_position=rng.uniform(60, 140),
            color=(rng.randint(180, 255), 0, 0),
            lifetime_frames=600,
        ))


@_register("SHOCKWAVE BLAST", "[BOOM]", "shockwave")
def _ch_shockwave(balls, arena, hazards, rng, config, **kw):
    ax1, ay1, ax2, ay2 = arena
    thick = rng.uniform(10, 18)
    hazards.shockwaves.append(Shockwave(
        cx=rng.uniform(ax1 + 50, ax2 - 50),
        cy=rng.uniform(ay1 + 50, ay2 - 50),
        speed=rng.uniform(2.5, 5.0),
        max_radius=min(ax2 - ax1, ay2 - ay1) * rng.uniform(0.5, 0.8),
        thickness=thick,
        kill_thickness=thick,  # equal to visual thickness
        color=(255, 255, rng.randint(50, 200)),
    ))


@_register("METEOR SHOWER", "[COMET]", "meteor")
def _ch_meteor(balls, arena, hazards, rng, config, **kw):
    ax1, ay1, ax2, ay2 = arena
    for _ in range(rng.randint(4, 8)):
        tx = rng.uniform(ax1 + 30, ax2 - 30)
        ty = rng.uniform(ay1 + 30, ay2 - 30)
        hazards.meteors.append(Meteor(
            target_x=tx, target_y=ty,
            current_y=ay1 - rng.uniform(100, 300),
            x=tx,
            speed=rng.uniform(4, 7),
            radius=rng.uniform(10, 16),
            blast_radius=rng.uniform(30, 60),  # reduced from 50-100
        ))


@_register("SPIKE MINEFIELD", "[!]", "spikes")
def _ch_spikes(balls, arena, hazards, rng, config, **kw):
    ax1, ay1, ax2, ay2 = arena
    alive_balls = [b for b in balls if b.alive]
    for _ in range(rng.randint(8, 15)):
        sr = rng.uniform(10, 20)
        sx, sy = rng.uniform(ax1 + 30, ax2 - 30), rng.uniform(ay1 + 30, ay2 - 30)
        for _attempt in range(20):
            sx = rng.uniform(ax1 + 30, ax2 - 30)
            sy = rng.uniform(ay1 + 30, ay2 - 30)
            if not any(math.hypot(b.x - sx, b.y - sy) < b.radius + sr + 20
                       for b in alive_balls):
                break
        hazards.spikes.append(Spike(
            x=sx, y=sy,
            radius=sr,
            pulse_phase=rng.uniform(0, math.pi * 2),
            warmup_frames=30,
        ))


