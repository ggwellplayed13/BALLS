class Ball:
    __slots__ = (
        "id", "x", "y", "vx", "vy", "radius", "color", "accent",
        "alive", "death_frame", "trail", "name", "flash_timer",
        "invincible_timer", "outline_color", "character", "emoji",
        "symbol", "original_radius",
    )

    def __init__(self, ball_id: int, x: float, y: float, radius: int,
                 color: Tuple[int, int, int], rng: random.Random,
                 character: Dict[str, Any]):
        self.id = ball_id
        self.x = x
        self.y = y
        speed = rng.uniform(1.2, 3.0)
        angle = rng.uniform(0, 2 * math.pi)
        self.vx = math.cos(angle) * speed
        self.vy = math.sin(angle) * speed
        self.radius = radius
        self.original_radius = radius
        self.color = color
        self.accent = tuple(min(255, c + 80) for c in color)
        self.outline_color = tuple(max(0, c - 60) for c in color)
        self.alive = True
        self.death_frame = -1
        self.trail: List[Tuple[float, float]] = []
        self.name = character["name"]
        self.emoji = character["emoji"]
        self.symbol = character["symbol"]
        self.flash_timer = 0.0
        self.invincible_timer = 0.0
        self.character = character


