@_register("TELEPORT SHUFFLE", "[TP]", "teleport")
def _ch_teleport(balls, arena, hazards, rng, config, **kw):
    ax1, ay1, ax2, ay2 = arena
    for b in balls:
        if b.alive:
            nx, ny = b.x, b.y
            for _attempt in range(25):
                cx_t = rng.uniform(ax1 + 30, ax2 - 30)
                cy_t = rng.uniform(ay1 + 30, ay2 - 30)
                safe = True
                # Check lava zones
                for lz in hazards.lava_zones:
                    if lz.warmup_frames > 0:
                        continue
                    th = lz.thickness + b.radius + 15
                    if lz.side == "bottom" and cy_t + b.radius > ay2 - th:
                        safe = False; break
                    if lz.side == "top" and cy_t - b.radius < ay1 + th:
                        safe = False; break
                    if lz.side == "left" and cx_t - b.radius < ax1 + th:
                        safe = False; break
                    if lz.side == "right" and cx_t + b.radius > ax2 - th:
                        safe = False; break
                if not safe:
                    continue
                # Check spikes
                for sp in hazards.spikes:
                    if sp.warmup_frames > 0:
                        continue
                    if math.hypot(cx_t - sp.x, cy_t - sp.y) < sp.radius + b.radius + 10:
                        safe = False; break
                if not safe:
                    continue
                # Check vortex kill zones
                for v in hazards.vortices:
                    if math.hypot(cx_t - v.x, cy_t - v.y) < v.kill_radius + b.radius + 15:
                        safe = False; break
                if safe:
                    nx, ny = cx_t, cy_t
                    break
            b.x = nx
            b.y = ny
            b.invincible_timer = max(b.invincible_timer, 1.5)  # 1.5s invincibility


