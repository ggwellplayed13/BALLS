# SECTION 7 — HAZARD MANAGER (controla TODOS los objetos destructivos)
# ═══════════════════════════════════════════════════════════════════════════════

class HazardManager:
    """Maneja la creación, actualización y detección de colisiones de todos
    los hazards visibles del juego."""

    def __init__(self, config: Config, rng: random.Random):
        self.config = config
        self.rng = rng
        # ── Hazard lists ──
        self.fireballs: List[Fireball] = []
        self.spinning_lasers: List[SpinningLaser] = []
        self.death_walls: List[DeathWall] = []
        self.shockwaves: List[Shockwave] = []
        self.meteors: List[Meteor] = []
        self.spikes: List[Spike] = []
        self.lava_zones: List[LavaZone] = []
        self.vortices: List[Vortex] = []

    # ──────────────────────────────────────────────────────────────────────────
    # UPDATE — mover todos los hazards
    # ──────────────────────────────────────────────────────────────────────────
    def update(self, t: float, frame: int, arena: Tuple[int, int, int, int]):
        ax1, ay1, ax2, ay2 = arena

        # Fireballs: rebotan dentro de la arena
        for fb in self.fireballs:
            fb.trail.append((fb.x, fb.y))
            if len(fb.trail) > 12:
                fb.trail.pop(0)
            fb.x += fb.vx
            fb.y += fb.vy
            if fb.x - fb.radius < ax1:
                fb.x = ax1 + fb.radius
                fb.vx = abs(fb.vx)
            if fb.x + fb.radius > ax2:
                fb.x = ax2 - fb.radius
                fb.vx = -abs(fb.vx)
            if fb.y - fb.radius < ay1:
                fb.y = ay1 + fb.radius
                fb.vy = abs(fb.vy)
            if fb.y + fb.radius > ay2:
                fb.y = ay2 - fb.radius
                fb.vy = -abs(fb.vy)
            fb.lifetime -= 1.0 / self.config.fps

        self.fireballs = [f for f in self.fireballs if f.lifetime > 0]

        # Spinning lasers: rotan, cuentan warmup y lifetime
        for sl in self.spinning_lasers:
            sl.angle += sl.speed
            if sl.warmup_frames > 0:
                sl.warmup_frames -= 1
            sl.lifetime_frames -= 1
        self.spinning_lasers = [sl for sl in self.spinning_lasers
                                 if sl.lifetime_frames > 0]

        # Death walls: avanzan hasta max_position, luego retroceden y se eliminan
        for dw in self.death_walls:
            if dw.warmup_frames > 0:
                dw.warmup_frames -= 1
            if dw.retreating:
                dw.position = max(0.0, dw.position - dw.speed)
            elif dw.position < dw.max_position:
                dw.position += dw.speed
            dw.lifetime_frames -= 1
            if dw.lifetime_frames <= 0 and not dw.retreating:
                dw.retreating = True
        self.death_walls = [dw for dw in self.death_walls
                            if not dw.retreating or dw.position > 0]

        # Shockwaves: se expanden
        for sw in self.shockwaves:
            if not sw.done:
                sw.current_radius += sw.speed
                if sw.current_radius >= sw.max_radius:
                    sw.done = True
        self.shockwaves = [s for s in self.shockwaves if not s.done]

        # Meteors: caen
        for m in self.meteors:
            if not m.exploded:
                m.current_y += m.speed
                if m.current_y >= m.target_y:
                    m.exploded = True
                    m.explosion_frame = frame
        self.meteors = [m for m in self.meteors
                        if not m.exploded or frame - m.explosion_frame < 30]

        # Spikes: pulsan, cuentan warmup
        for sp in self.spikes:
            sp.pulse_phase += 0.1
            if sp.warmup_frames > 0:
                sp.warmup_frames -= 1

        # Lava: crece gradualmente, cuenta warmup
        for lz in self.lava_zones:
            if lz.warmup_frames > 0:
                lz.warmup_frames -= 1
            if lz.thickness < lz.max_thickness:
                lz.thickness += lz.grow_speed

        # Vortices: rotan, cuentan lifetime
        for v in self.vortices:
            v.rotation += 0.08
            v.lifetime_frames -= 1
        self.vortices = [v for v in self.vortices if v.lifetime_frames > 0]

        # Limitar cantidades de todos los tipos de hazards
        if len(self.spikes) > 35:
            self.spikes = self.spikes[-30:]
        if len(self.fireballs) > 8:
            self.fireballs = self.fireballs[-6:]
        if len(self.spinning_lasers) > 3:
            self.spinning_lasers = self.spinning_lasers[-3:]
        if len(self.death_walls) > 4:
            self.death_walls = self.death_walls[-4:]
        if len(self.vortices) > 3:
            self.vortices = self.vortices[-3:]

    # ──────────────────────────────────────────────────────────────────────────
    # CHECK COLLISIONS — ¿esta bola debe morir?
    # ──────────────────────────────────────────────────────────────────────────
    def check_ball_death(self, ball: Ball, frame: int,
                         arena: Tuple[int, int, int, int]) -> bool:
        """Retorna True si la bola colisiona con algún hazard letal."""
        if not ball.alive or ball.invincible_timer > 0:
            return False
        bx, by, br = ball.x, ball.y, ball.radius
        ax1, ay1, ax2, ay2 = arena

        # ── Fireballs ──
        for fb in self.fireballs:
            dist = math.hypot(bx - fb.x, by - fb.y)
            if dist < fb.radius + br:
                return True

        # ── Spinning Lasers ──
        for sl in self.spinning_lasers:
            if sl.warmup_frames > 0:
                continue
            for arm_i in range(sl.arms):
                arm_angle = sl.angle + arm_i * (2 * math.pi / sl.arms)
                ex = sl.cx + math.cos(arm_angle) * sl.length
                ey = sl.cy + math.sin(arm_angle) * sl.length
                dist = self._point_line_dist(bx, by, sl.cx, sl.cy, ex, ey)
                if dist < sl.kill_radius + br:
                    return True

        # ── Death Walls ──
        for dw in self.death_walls:
            if dw.warmup_frames > 0 or dw.retreating or dw.position <= 0:
                continue
            if dw.side == "left" and bx - br < ax1 + dw.position:
                return True
            if dw.side == "right" and bx + br > ax2 - dw.position:
                return True
            if dw.side == "top" and by - br < ay1 + dw.position:
                return True
            if dw.side == "bottom" and by + br > ay2 - dw.position:
                return True

        # ── Shockwaves ──
        for sw in self.shockwaves:
            dist = math.hypot(bx - sw.cx, by - sw.cy)
            kill_th = min(sw.kill_thickness, sw.thickness)  # never wider than visual
            inner = sw.current_radius - kill_th / 2
            outer = sw.current_radius + kill_th / 2
            if inner < dist < outer:
                return True

        # ── Meteors (explosión) ──
        for m in self.meteors:
            if m.exploded and frame - m.explosion_frame < 4:  # reduced from 8 to 4
                dist = math.hypot(bx - m.target_x, by - m.target_y)
                if dist < m.blast_radius:
                    return True

        # ── Spikes ──
        for sp in self.spikes:
            if sp.warmup_frames > 0:
                continue
            pulse = 1.0 + 0.15 * math.sin(sp.pulse_phase)
            if math.hypot(bx - sp.x, by - sp.y) < sp.radius * pulse + br:
                return True

        # ── Lava Zones ──
        for lz in self.lava_zones:
            if lz.warmup_frames > 0:
                continue
            th = lz.thickness
            if th <= 0:
                continue
            if lz.side == "bottom" and by + br > ay2 - th:
                return True
            if lz.side == "top" and by - br < ay1 + th:
                return True
            if lz.side == "left" and bx - br < ax1 + th:
                return True
            if lz.side == "right" and bx + br > ax2 - th:
                return True

        # ── Vortex center kill ──
        for v in self.vortices:
            if math.hypot(bx - v.x, by - v.y) < v.kill_radius:
                return True

        return False

    # ──────────────────────────────────────────────────────────────────────────
    # VORTEX PULL — fuerza de atracción
    # ──────────────────────────────────────────────────────────────────────────
    def apply_vortex_force(self, ball: Ball):
        for v in self.vortices:
            dx = v.x - ball.x
            dy = v.y - ball.y
            dist = math.hypot(dx, dy)
            if 0 < dist < v.radius:
                force = v.strength * (1.0 - dist / v.radius) / max(dist, 1.0)
                ball.vx += dx * force * 0.04
                ball.vy += dy * force * 0.04

    @staticmethod
    def _point_line_dist(px, py, x1, y1, x2, y2) -> float:
        dx, dy = x2 - x1, y2 - y1
        if dx == 0 and dy == 0:
            return math.hypot(px - x1, py - y1)
        t = max(0, min(1, ((px - x1) * dx + (py - y1) * dy) / (dx * dx + dy * dy)))
        return math.hypot(px - (x1 + t * dx), py - (y1 + t * dy))

