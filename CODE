    available_sides = [s for s in ["bottom", "left", "right", "top"]
                       if s not in existing_sides]
    if available_sides:
        sides_to_add = rng.sample(available_sides,
                                   min(len(available_sides), rng.randint(1, 2)))
        for side in sides_to_add:
            hazards.lava_zones.append(LavaZone(
                side=side,
                grow_speed=rng.uniform(0.04, 0.12),
                max_thickness=rng.uniform(40, 90),
                warmup_frames=60,
            ))
    else:
        for lz in hazards.lava_zones:
            arena_w = arena[2] - arena[0]
            arena_h = arena[3] - arena[1]
            lz.max_thickness = min(
                lz.max_thickness + rng.uniform(10, 25),
                min(arena_w, arena_h) * 0.25)
