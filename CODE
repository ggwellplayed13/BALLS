class Renderer:
    def __init__(self, config: Config, character_images: Dict[str, Image.Image]):
        self.config = config
        self.w = config.width
        self.h = config.height
        self._font_cache: Dict[int, Any] = {}
        self._death_particles: List[Dict] = []
        self._bubble_particles: List[Dict] = []
        self._event_display: List[Tuple[int, str]] = []
        self._challenge_banner: Optional[Tuple[int, str, str]] = None
        self._character_images = character_images
        self._elimination_feed: List[Tuple[int, str, Tuple[int, int, int]]] = []
        self._screen_shake: float = 0.0
        self._background_img: Optional[Image.Image] = None

        if config.background_image_path and os.path.exists(config.background_image_path):
            try:
                bg = Image.open(config.background_image_path).convert("RGB")
                self._background_img = bg.resize((config.width, config.height),
                                                  Image.LANCZOS)
            except Exception:
                self._background_img = None

    # ── Font helper ──
    def _font(self, size: int):
        size = max(size, 8)
        if size not in self._font_cache:
            for path in [
                "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
                "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf",
            ]:
                if os.path.exists(path):
                    self._font_cache[size] = ImageFont.truetype(path, size)
                    return self._font_cache[size]
            self._font_cache[size] = ImageFont.load_default()
        return self._font_cache[size]

    # ── Outlined text ──
    def _outlined_text(self, draw, pos, text, font, fill, outline=(0, 0, 0),
                       outline_w=3):
        x, y = pos
        for dx in range(-outline_w, outline_w + 1):
            for dy in range(-outline_w, outline_w + 1):
                if dx * dx + dy * dy <= outline_w * outline_w:
                    draw.text((x + dx, y + dy), text, font=font, fill=outline)
        draw.text((x, y), text, font=font, fill=fill)

    # ── Event text ──
    def add_event_text(self, frame: int, text: str, duration_frames: int = 50):
        self._event_display.append((frame + duration_frames, text))

    # ── Challenge banner ──
    def set_challenge_banner(self, frame: int, name: str, emoji: str,
                             duration_frames: int = 90):
        self._challenge_banner = (frame + duration_frames, name, emoji)

    # ── Screen shake ──
    def trigger_screen_shake(self, intensity: float = 6.0):
        self._screen_shake = max(self._screen_shake, intensity)

    # ── Death particles ──
    def add_death_particles(self, x: float, y: float,
                            color: Tuple[int, int, int], frame: int):
        for _ in range(18):
            angle = random.uniform(0, 2 * math.pi)
            speed = random.uniform(2, 9)
            self._death_particles.append({
                "x": x, "y": y,
                "vx": math.cos(angle) * speed,
                "vy": math.sin(angle) * speed,
                "color": color, "life": 1.0,
                "size": random.uniform(2, 7),
            })

    # ── Bubble explosion ──
    def add_bubble_explosion(self, x: float, y: float,
                             color: Tuple[int, int, int], frame: int):
        for _ in range(random.randint(8, 16)):
            angle = random.uniform(0, 2 * math.pi)
            speed = random.uniform(1.0, 4.5)
            br = random.uniform(4, 14)
            self._bubble_particles.append({
                "x": x, "y": y,
                "vx": math.cos(angle) * speed,
                "vy": math.sin(angle) * speed - random.uniform(0.5, 2.0),
                "radius": br,
                "max_radius": br * random.uniform(1.3, 2.0),
                "color": color, "life": 1.0,
                "decay": random.uniform(0.015, 0.035),
                "wobble_phase": random.uniform(0, math.pi * 2),
                "wobble_speed": random.uniform(0.1, 0.3),
            })
        self.trigger_screen_shake(4.0)

    # ── Elimination feed ──
    def add_elimination(self, frame: int, name: str, color: Tuple[int, int, int]):
        self._elimination_feed.append((frame + 90, name, color))
        if len(self._elimination_feed) > 5:
            self._elimination_feed = self._elimination_feed[-5:]

    # ══════════════════════════════════════════════════════════════════════════
    # MAIN RENDER FRAME
    # ══════════════════════════════════════════════════════════════════════════
    def render_frame(self, t: float, frame: int, balls: List[Ball],
                     arena: Tuple[int, int, int, int],
                     hazards: HazardManager,
                     alive_count: int, total: int,
                     winner: Optional[Ball],
                     phase: str,
                     selected_challenges: List[Dict],
                     challenge_index: int) -> np.ndarray:
        w, h = self.w, self.h
        ax1, ay1, ax2, ay2 = arena

        # Screen shake offset
        shake_x, shake_y = 0, 0
        if self._screen_shake > 0.5:
            shake_x = int(random.uniform(-self._screen_shake, self._screen_shake))
            shake_y = int(random.uniform(-self._screen_shake, self._screen_shake))
            self._screen_shake *= 0.88

        # Background
        if self._background_img is not None:
            img = self._background_img.copy()
            dark = Image.new("RGB", (w, h), (0, 0, 0))
            img = Image.blend(img, dark, 0.4)
        else:
            img = Image.new("RGB", (w, h), (10, 8, 18))

        draw = ImageDraw.Draw(img)

        # Grid
        if self._background_img is None:
            grid_c = (25, 22, 40)
            for gx in range(0, w, 40):
                draw.line([(gx, 0), (gx, h)], fill=grid_c, width=1)
            for gy in range(0, h, 40):
                draw.line([(0, gy), (w, gy)], fill=grid_c, width=1)

        # Arena background gradient
        for row_i in range(max(0, ay1), min(h, ay2)):
            rp = (row_i - ay1) / max(1, ay2 - ay1)
            rb = int(self.config.arena_color[0] + rp * 8)
            gb = int(self.config.arena_color[1] + rp * 5)
            bb = int(self.config.arena_color[2] + rp * 12)
            draw.line([(ax1, row_i), (ax2, row_i)],
                      fill=(min(255, rb), min(255, gb), min(255, bb)))

        # ── Render hazards ──
        self._render_hazards(draw, img, hazards, arena, frame, t)

        # Arena border
        progress = min(1.0, t / self.config.duration)
        pulse = 1.0 + 0.3 * math.sin(t * 3)
        bw = max(2, int(self.config.arena_border_width * pulse))
        br_c = int(255 * (0.5 + 0.5 * progress))
        bg_c = int(255 * (1.0 - progress * 0.7))
        bb_c = int(255 * (1.0 - progress * 0.8))
        draw.rectangle([ax1, ay1, ax2, ay2], outline=(br_c, bg_c, bb_c), width=bw)

        # Corner markers
        ms = 12 + int(6 * math.sin(t * 5))
        for cx_m, cy_m in [(ax1, ay1), (ax2, ay1), (ax1, ay2), (ax2, ay2)]:
            draw.rectangle([cx_m - ms // 2, cy_m - ms // 2,
                            cx_m + ms // 2, cy_m + ms // 2],
                           fill=(255, 50, 50))

        # Death particles
        self._update_and_render_particles(draw, frame)

        # Bubble particles
        self._update_and_render_bubbles(draw, img, frame)

        # Render balls
        alive_balls = sorted([b for b in balls if b.alive], key=lambda b: b.y)
        for ball in alive_balls:
            self._render_ball(draw, img, ball, frame)

        # HUD
        self._render_hud(draw, img, t, frame, alive_count, total, phase,
                         winner, balls, selected_challenges, challenge_index)

        # Elimination feed
        self._render_elimination_feed(draw, frame)

        # Challenge banner
        self._render_challenge_banner(draw, frame)

        # Phase overlays
        if phase == "countdown":
            self._render_countdown(draw, t)
        elif phase == "winner" and winner:
            img = self._render_winner_screen(img, draw, winner, t, frame)

        # Apply screen shake
        if abs(shake_x) > 0 or abs(shake_y) > 0:
            shifted = Image.new("RGB", (w, h), (10, 8, 18))
            shifted.paste(img, (shake_x, shake_y))
            img = shifted

        return np.array(img, dtype=np.uint8)

    # ══════════════════════════════════════════════════════════════════════════
    # RENDER INDIVIDUAL BALL (with character image)
    # ══════════════════════════════════════════════════════════════════════════
    def _render_ball(self, draw: ImageDraw.Draw, img: Image.Image,
                     ball: Ball, frame: int):
        x, y, r = int(ball.x), int(ball.y), ball.radius

        # Trail
        for i, (tx, ty) in enumerate(ball.trail):
            af = (i + 1) / (len(ball.trail) + 1)
            tr = max(2, int(r * af * 0.5))
            c = tuple(int(v * af * 0.4) for v in ball.color)
            draw.ellipse([int(tx) - tr, int(ty) - tr,
                          int(tx) + tr, int(ty) + tr], fill=c)

        # Shadow
        draw.ellipse([x - r + 3, y - r + 3, x + r + 3, y + r + 3],
                     fill=(0, 0, 0))

        # Invincible glow
        if ball.invincible_timer > 0:
            gr = r + 5 + int(math.sin(frame * 0.5) * 3)
            draw.ellipse([x - gr, y - gr, x + gr, y + gr],
                         outline=(255, 255, 100), width=3)

        # Main ball color background
        draw.ellipse([x - r, y - r, x + r, y + r], fill=ball.color)

        # Character image overlay — covers the full ball circle
        char_img = self._character_images.get(ball.name)
        if char_img is not None:
            diam = r * 2
            if diam >= 6:
                try:
                    resized = char_img.resize((diam, diam), Image.LANCZOS)
                    mask = Image.new("L", (diam, diam), 0)
                    mask_draw = ImageDraw.Draw(mask)
                    mask_draw.ellipse([0, 0, diam - 1, diam - 1], fill=255)
                    px = x - r
                    py = y - r
                    img.paste(resized, (px, py), mask)
                except Exception:
                    pass

        # Ball outline drawn AFTER image paste
        draw.ellipse([x - r, y - r, x + r, y + r],
                     outline=ball.outline_color,
                     width=self.config.ball_outline_width)

        # Name label
        if r >= 8:
            nf = self._font(max(8, min(12, r - 1)))
            short = ball.name[:8]
            bbox_n = draw.textbbox((0, 0), short, font=nf)
            tw_n = bbox_n[2] - bbox_n[0]
            lx = x - tw_n // 2
            ly = y + r + 3
            self._outlined_text(draw, (lx, ly), short, nf,
                                (255, 255, 255), outline_w=2)

    # ══════════════════════════════════════════════════════════════════════════
    # RENDER HAZARDS (all visible destructive objects)
    # ══════════════════════════════════════════════════════════════════════════
    def _render_hazards(self, draw: ImageDraw.Draw, img: Image.Image,
                        hazards: HazardManager,
                        arena: Tuple[int, int, int, int],
                        frame: int, t: float):
        ax1, ay1, ax2, ay2 = arena

        # ── Lava Zones ──
        for lz in hazards.lava_zones:
            if lz.thickness <= 0:
                continue
            th = int(lz.thickness)
            flicker = int(random.uniform(-8, 8))
            in_warmup = lz.warmup_frames > 0
            if in_warmup:
                # During warmup: show as dark orange/yellow warning, not lethal
                lava_colors = [
                    (200, 100 + flicker, 0),
                    (220, 160 + flicker, 0),
                    (240, 200, 30),
                ]
            else:
                lava_colors = [
                    (255, 60 + flicker, 0),
                    (255, 120 + flicker, 0),
                    (255, 180, 50),
                ]
            if lz.side == "bottom":
                for row in range(min(th, ay2 - ay1)):
                    yl = ay2 - th + row
                    if ay1 <= yl <= ay2:
                        ci = min(len(lava_colors) - 1,
                                 int(row / max(1, th) * len(lava_colors)))
                        draw.line([(ax1 + 1, yl), (ax2 - 1, yl)],
                                  fill=lava_colors[ci])
            elif lz.side == "top":
                for row in range(min(th, ay2 - ay1)):
                    yl = ay1 + row
                    if ay1 <= yl <= ay2:
                        ci = min(len(lava_colors) - 1,
                                 int((1.0 - row / max(1, th)) * len(lava_colors)))
                        draw.line([(ax1 + 1, yl), (ax2 - 1, yl)],
                                  fill=lava_colors[ci])
            elif lz.side == "left":
                for col in range(min(th, ax2 - ax1)):
                    xl = ax1 + col
                    if ax1 <= xl <= ax2:
                        ci = min(len(lava_colors) - 1,
                                 int((1.0 - col / max(1, th)) * len(lava_colors)))
                        draw.line([(xl, ay1 + 1), (xl, ay2 - 1)],
                                  fill=lava_colors[ci])
            elif lz.side == "right":
                for col in range(min(th, ax2 - ax1)):
                    xl = ax2 - th + col
                    if ax1 <= xl <= ax2:
                        ci = min(len(lava_colors) - 1,
                                 int(col / max(1, th) * len(lava_colors)))
                        draw.line([(xl, ay1 + 1), (xl, ay2 - 1)],
                                  fill=lava_colors[ci])
            # Lava bubbles
            if th > 5:
                for _ in range(3):
                    if lz.side == "bottom":
                        bx = random.randint(ax1 + 5, max(ax1 + 6, ax2 - 5))
                        by = ay2 - random.randint(2, max(3, th))
                    elif lz.side == "top":
                        bx = random.randint(ax1 + 5, max(ax1 + 6, ax2 - 5))
                        by = ay1 + random.randint(2, max(3, th))
                    elif lz.side == "left":
                        bx = ax1 + random.randint(2, max(3, th))
                        by = random.randint(ay1 + 5, max(ay1 + 6, ay2 - 5))
                    else:
                        bx = ax2 - random.randint(2, max(3, th))
                        by = random.randint(ay1 + 5, max(ay1 + 6, ay2 - 5))
                    bbr = random.randint(2, 5)
                    draw.ellipse([bx - bbr, by - bbr, bx + bbr, by + bbr],
                                 fill=(255, 220, 80))

        # ── Spikes ──
        for sp in hazards.spikes:
            pulse = 1.0 + 0.15 * math.sin(sp.pulse_phase)
            sr_s = int(sp.radius * pulse)
            sx, sy = int(sp.x), int(sp.y)
            in_warmup = sp.warmup_frames > 0
            points = []
            num_pts = 8
            for ip in range(num_pts * 2):
                a = ip * math.pi / num_pts - math.pi / 2
                r_s = sr_s if ip % 2 == 0 else sr_s // 2
                points.append((sx + int(math.cos(a) * r_s),
                                sy + int(math.sin(a) * r_s)))
            if len(points) >= 3:
                fill_c = (150, 150, 200) if in_warmup else (200, 200, 200)
                outline_c = (255, 220, 0) if in_warmup else (255, 80, 80)
                draw.polygon(points, fill=fill_c,
                             outline=outline_c, width=2)
            draw.ellipse([sx - sr_s - 3, sy - sr_s - 3,
                          sx + sr_s + 3, sy + sr_s + 3],
                         outline=(255, 220, 0) if in_warmup else (255, 50, 50), width=1)

        # ── Fireballs (bola de fuego que rebota) ──
        for fb in hazards.fireballs:
            # Trail glow
            for i_t, (tx, ty) in enumerate(fb.trail):
                af = (i_t + 1) / (len(fb.trail) + 1)
                tr = max(2, int(fb.radius * af * 0.8))
                fc = tuple(int(c * af * 0.6) for c in fb.color)
                draw.ellipse([int(tx) - tr, int(ty) - tr,
                              int(tx) + tr, int(ty) + tr], fill=fc)
            # Outer glow
            gr = int(fb.radius * 1.6)
            fbx, fby = int(fb.x), int(fb.y)
            draw.ellipse([fbx - gr, fby - gr, fbx + gr, fby + gr],
                         fill=(255, 80, 0))
            # Core
            fbr = int(fb.radius)
            draw.ellipse([fbx - fbr, fby - fbr, fbx + fbr, fby + fbr],
                         fill=fb.color, outline=(255, 255, 100), width=2)
            # Inner bright core
            cr = max(2, fbr // 2)
            draw.ellipse([fbx - cr, fby - cr, fbx + cr, fby + cr],
                         fill=(255, 255, 200))


        # ── Spinning Lasers ──
        for sl in hazards.spinning_lasers:
            scx, scy = int(sl.cx), int(sl.cy)
            in_warmup = sl.warmup_frames > 0
            beam_color = (255, 200, 0) if in_warmup else sl.color
            glow_color = (200, 150, 0) if in_warmup else (255, 50, 50)
            for arm_i in range(sl.arms):
                arm_angle = sl.angle + arm_i * (2 * math.pi / sl.arms)
                ex = int(sl.cx + math.cos(arm_angle) * sl.length)
                ey = int(sl.cy + math.sin(arm_angle) * sl.length)
                # Outer glow
                draw.line([(scx, scy), (ex, ey)],
                          fill=glow_color, width=int(sl.thickness + 8))
                # Core beam
                draw.line([(scx, scy), (ex, ey)],
                          fill=beam_color, width=int(sl.thickness))
                # Inner core color
                inner_c = (255, 255, 200) if in_warmup else (255, 200, 200)
                draw.line([(scx, scy), (ex, ey)],
                          fill=inner_c,
                          width=max(1, int(sl.thickness // 3)))
            # Center hub
            draw.ellipse([scx - 10, scy - 10, scx + 10, scy + 10],
                         fill=(255, 200, 100) if in_warmup else (255, 100, 100),
                         outline=(255, 255, 255), width=2)


        # ── Death Walls ──
        for dw in hazards.death_walls:
            if dw.position <= 0:
                continue
            pos = int(dw.position)
            if dw.side == "left":
                draw.rectangle([ax1, ay1, ax1 + pos, ay2], fill=dw.color)
                # Warning stripes
                for sy_s in range(ay1, ay2, 20):
                    draw.rectangle([ax1 + pos - 6, sy_s,
                                    ax1 + pos, sy_s + 10],
                                   fill=(255, 255, 0))
            elif dw.side == "right":
                draw.rectangle([ax2 - pos, ay1, ax2, ay2], fill=dw.color)
                for sy_s in range(ay1, ay2, 20):
                    draw.rectangle([ax2 - pos, sy_s,
                                    ax2 - pos + 6, sy_s + 10],
                                   fill=(255, 255, 0))
            elif dw.side == "top":
                draw.rectangle([ax1, ay1, ax2, ay1 + pos], fill=dw.color)
                for sx_s in range(ax1, ax2, 20):
                    draw.rectangle([sx_s, ay1 + pos - 6,
                                    sx_s + 10, ay1 + pos],
                                   fill=(255, 255, 0))
            elif dw.side == "bottom":
                draw.rectangle([ax1, ay2 - pos, ax2, ay2], fill=dw.color)
                for sx_s in range(ax1, ax2, 20):
                    draw.rectangle([sx_s, ay2 - pos,
                                    sx_s + 10, ay2 - pos + 6],
                                   fill=(255, 255, 0))

        # ── Shockwaves ──
        for sw in hazards.shockwaves:
            cr_s = int(sw.current_radius)
            if cr_s < 2:
                continue
            scx, scy = int(sw.cx), int(sw.cy)
            th_s = max(2, int(sw.thickness))
            # Outer ring
            draw.ellipse([scx - cr_s, scy - cr_s, scx + cr_s, scy + cr_s],
                         outline=sw.color, width=th_s)
            # Inner bright ring
            inner_r = max(1, cr_s - th_s // 2)
            draw.ellipse([scx - inner_r, scy - inner_r,
                          scx + inner_r, scy + inner_r],
                         outline=(255, 255, 255), width=max(1, th_s // 3))

        # ── Meteors ──
        for m in hazards.meteors:
            mtx, mty = int(m.target_x), int(m.target_y)
            if not m.exploded:
                # Warning circle on ground
                wr = int(m.blast_radius)
                # Pulsing warning
                pulse_a = int(80 + 40 * math.sin(frame * 0.3))
                draw.ellipse([mtx - wr, mty - wr, mtx + wr, mty + wr],
                             outline=(255, 50, 50), width=2)
                # X mark
                draw.line([(mtx - 8, mty - 8), (mtx + 8, mty + 8)],
                          fill=(255, 50, 50), width=2)
                draw.line([(mtx - 8, mty + 8), (mtx + 8, mty - 8)],
                          fill=(255, 50, 50), width=2)
                # Meteor in the sky falling
                mx = int(m.x)
                my = int(m.current_y)
                mr = int(m.radius)
                if my > ay1 - 200:
                    # Meteor body
                    draw.ellipse([mx - mr, my - mr, mx + mr, my + mr],
                                 fill=(180, 80, 0), outline=(255, 150, 50), width=2)
                    # Fire trail above
                    for t_i in range(5):
                        ty_m = my - t_i * 8 - mr
                        tr_m = max(1, mr - t_i * 2)
                        tc = (255, max(0, 200 - t_i * 40), 0)
                        draw.ellipse([mx - tr_m, ty_m - tr_m,
                                      mx + tr_m, ty_m + tr_m], fill=tc)
            else:
                # Explosion
                age = frame - m.explosion_frame
                if age < 30:
                    ep = age / 30.0
                    er = int(m.blast_radius * min(1.0, ep * 2))
                    alpha_f = 1.0 - ep
                    exp_colors = [(255, 255, 200), (255, 180, 50), (255, 80, 0)]
                    ci_e = min(len(exp_colors) - 1, int(ep * len(exp_colors)))
                    ec = tuple(int(v * alpha_f) for v in exp_colors[ci_e])
                    if er > 0:
                        draw.ellipse([mtx - er, mty - er, mtx + er, mty + er],
                                     fill=ec, outline=(255, 100, 0))

        # ── Vortices ──
        for v in hazards.vortices:
            vx, vy = int(v.x), int(v.y)
            vr = int(v.radius)
            # Spiral rings
            for ring in range(5, vr, 12):
                c_v = (min(255, 80 + ring), 30, min(255, 180 + ring // 2))
                for seg in range(16):
                    a1 = v.rotation + seg * math.pi / 8 + ring * 0.06
                    a2 = a1 + math.pi / 16
                    x1_v = vx + int(math.cos(a1) * ring)
                    y1_v = vy + int(math.sin(a1) * ring)
                    x2_v = vx + int(math.cos(a2) * ring)
                    y2_v = vy + int(math.sin(a2) * ring)
                    draw.line([(x1_v, y1_v), (x2_v, y2_v)], fill=c_v, width=2)
            # Kill zone center — made more visible with larger red circle
            kr = int(v.kill_radius)
            draw.ellipse([vx - kr - 4, vy - kr - 4, vx + kr + 4, vy + kr + 4],
                         fill=(180, 0, 0), outline=(255, 50, 50), width=3)
            draw.ellipse([vx - kr, vy - kr, vx + kr, vy + kr],
                         fill=(255, 0, 0), outline=(255, 180, 0), width=2)


    # ══════════════════════════════════════════════════════════════════════════
    # PARTICLES
    # ══════════════════════════════════════════════════════════════════════════
    def _update_and_render_particles(self, draw: ImageDraw.Draw, frame: int):
        surviving = []
        for p in self._death_particles:
            p["x"] += p["vx"]
            p["y"] += p["vy"]
            p["vy"] += 0.15
            p["life"] -= 0.04
            if p["life"] > 0:
                sz = max(1, int(p["size"] * p["life"]))
                c = tuple(max(0, int(v * p["life"])) for v in p["color"])
                px, py = int(p["x"]), int(p["y"])
                draw.ellipse([px - sz, py - sz, px + sz, py + sz], fill=c)
                surviving.append(p)
        self._death_particles = surviving

    def _update_and_render_bubbles(self, draw: ImageDraw.Draw,
                                    img: Image.Image, frame: int):
        surviving = []
        for b in self._bubble_particles:
            b["x"] += b["vx"]
            b["y"] += b["vy"]
            b["vy"] -= 0.08
            b["vx"] *= 0.98
            b["vy"] *= 0.98
            b["life"] -= b["decay"]
            b["wobble_phase"] += b["wobble_speed"]
            wobble = math.sin(b["wobble_phase"]) * 2.0
            life = b["life"]
            if life > 0.7:
                cur_r = b["radius"] + (b["max_radius"] - b["radius"]) * (1.0 - life) / 0.3
            elif life > 0:
                cur_r = b["max_radius"] * (life / 0.7)
            else:
                cur_r = 0
            if life > 0 and cur_r > 1:
                bx_b = int(b["x"] + wobble)
                by_b = int(b["y"])
                cr = max(1, int(cur_r))
                bc = b["color"]
                bf = tuple(min(255, c + 40) for c in bc)
                draw.ellipse([bx_b - cr, by_b - cr, bx_b + cr, by_b + cr],
                             outline=bf, width=max(1, cr // 4))
                hr = max(1, cr // 3)
                hx, hy = bx_b - cr // 4, by_b - cr // 4
                hc = tuple(min(255, c + 120) for c in bc)
                draw.ellipse([hx - hr, hy - hr, hx + hr, hy + hr], fill=hc)
                surviving.append(b)
        self._bubble_particles = surviving

    # ══════════════════════════════════════════════════════════════════════════
    # ELIMINATION FEED
    # ══════════════════════════════════════════════════════════════════════════
    def _render_elimination_feed(self, draw: ImageDraw.Draw, frame: int):
        self._elimination_feed = [(e, n, c) for e, n, c in
                                   self._elimination_feed if e > frame]
        if not self._elimination_feed:
            return
        ff = self._font(14)
        xp = self.w - 210
        yp = 180
        for i, (exp, name, color) in enumerate(self._elimination_feed[-4:]):
            remaining = exp - frame
            af = min(1.0, remaining / 30.0)
            draw.ellipse([xp, yp + i * 22, xp + 10, yp + i * 22 + 10],
                         fill=color)
            tc = tuple(int(200 * af) for _ in range(3))
            draw.text((xp + 14, yp + i * 22 - 2), f"X {name[:12]}",
                      font=ff, fill=tc)

    # ══════════════════════════════════════════════════════════════════════════
    # CHALLENGE BANNER
    # ══════════════════════════════════════════════════════════════════════════
    def _render_challenge_banner(self, draw: ImageDraw.Draw, frame: int):
        if self._challenge_banner is None:
            return
        expire, name, emoji = self._challenge_banner
        if frame > expire:
            self._challenge_banner = None
            return
        remaining = expire - frame
        total_dur = 90
        if remaining > total_dur - 10:
            slide = (total_dur - remaining) / 10.0
        elif remaining < 15:
            slide = remaining / 15.0
        else:
            slide = 1.0

        w = self.w
        bw_b = 500
        bh_b = 70
        bx_b = int((w - bw_b) / 2)
        by_b = int(220 + (1.0 - slide) * 100)

        draw.rounded_rectangle([bx_b, by_b, bx_b + bw_b, by_b + bh_b],
                               radius=15, fill=(20, 20, 50))
        draw.rounded_rectangle([bx_b, by_b, bx_b + bw_b, by_b + bh_b],
                               radius=15, outline=(255, 200, 50), width=3)

        hf = self._font(18)
        self._outlined_text(draw, (bx_b + 15, by_b + 5),
                            "> NEW CHALLENGE! <<", hf,
                            (255, 200, 50), outline_w=2)

        nf = self._font(26)
        ct = f"[ {name} ]"
        bbox_c = draw.textbbox((0, 0), ct, font=nf)
        tw_c = bbox_c[2] - bbox_c[0]
        nx = bx_b + (bw_b - tw_c) // 2
        self._outlined_text(draw, (nx, by_b + 34), ct, nf,
                            (255, 255, 255), outline_w=3)

    # ══════════════════════════════════════════════════════════════════════════
    # HUD
    # ══════════════════════════════════════════════════════════════════════════
    def _render_hud(self, draw: ImageDraw.Draw, img: Image.Image,
                    t: float, frame: int, alive: int, total: int,
                    phase: str, winner: Optional[Ball],
                    balls: List[Ball],
                    selected_challenges: List[Dict],
                    challenge_index: int):
        w, h = self.w, self.h
        if phase == "countdown":
            return

        # Title
        tf = self._font(30)
        title = "> BRAINROT BATTLE ROYALE <<"
        bbox_t = draw.textbbox((0, 0), title, font=tf)
        tw_t = bbox_t[2] - bbox_t[0]
        self._outlined_text(draw, ((w - tw_t) // 2, 12), title, tf,
                            (255, 255, 255))

        # Alive counter
        cfs = 52
        if alive <= 10:
            p = 1.0 + 0.15 * math.sin(frame * 0.3)
            cfs = int(52 * p)
        cf = self._font(cfs)
        ct = str(alive)
        bbox_c = draw.textbbox((0, 0), ct, font=cf)
        tw_c = bbox_c[2] - bbox_c[0]

        if alive > 50:
            cc = (100, 255, 100)
        elif alive > 20:
            cc = (255, 255, 100)
        elif alive > 5:
            cc = (255, 150, 50)
        else:
            cc = (255, 50, 50)

        self._outlined_text(draw, ((w - tw_c) // 2, 52), ct, cf, cc, outline_w=4)

        lf = self._font(22)
        self._outlined_text(draw, ((w - 42) // 2, 108), "ALIVE", lf,
                            (200, 200, 200))

        # Timer
        tmf = self._font(22)
        self._outlined_text(draw, (w - 120, 12), f"T: {t:.1f}s", tmf,
                            (200, 200, 200))

        # Challenge sidebar
        chf = self._font(13)
        chf_h = self._font(15)
        cx_ch, cy_ch = 8, 155
        self._outlined_text(draw, (cx_ch, cy_ch), "CHALLENGES:", chf_h,
                            (255, 200, 100), outline_w=2)
        cy_ch += 20
        for idx, ch in enumerate(selected_challenges):
            if idx < challenge_index:
                sc, prefix = (100, 100, 100), "[X]"
            elif idx == challenge_index:
                sc, prefix = (255, 255, 50), ">>>"
            else:
                sc, prefix = (150, 150, 150), "..."
            self._outlined_text(draw, (cx_ch, cy_ch),
                                f"{prefix} {ch['emoji'][:12]} {ch['name'][:14]}",
                                chf, sc, outline_w=1)
            cy_ch += 18

        # Event notifications
        self._event_display = [(e, t_e) for e, t_e in self._event_display
                                if e > frame]
        y_off = 310
        ef = self._font(26)
        for _, txt in self._event_display[-3:]:
            bbox_e = draw.textbbox((0, 0), txt, font=ef)
            tw_e = bbox_e[2] - bbox_e[0]
            self._outlined_text(draw, ((w - tw_e) // 2, y_off), txt,
                                ef, (255, 220, 50), outline_w=3)
            y_off += 34

        # Progress bar
        bar_x, bar_y = 30, h - 50
        bar_w, bar_h_s = w - 60, 14
        progress = min(1.0, t / self.config.duration)
        draw.rounded_rectangle([bar_x, bar_y, bar_x + bar_w,
                                bar_y + bar_h_s], radius=7, fill=(40, 40, 40))
        fill_w = int(bar_w * (1.0 - progress))
        if fill_w > 0:
            for i_b in range(fill_w):
                ratio = i_b / max(1, bar_w)
                draw.line([(bar_x + i_b, bar_y + 1),
                           (bar_x + i_b, bar_y + bar_h_s - 1)],
                          fill=(int(50 + 205 * ratio),
                                int(255 * (1.0 - ratio)), 50))

        bf = self._font(13)
        self._outlined_text(draw, (bar_x, bar_y - 16), "ARENA SIZE",
                            bf, (180, 180, 180), outline_w=2)

        # Engagement hooks
        pp = progress
        if 0.30 < pp < 0.34 and alive > 30:
            hf = self._font(34)
            hook = "WHO WILL SURVIVE?"
            bbox_h = draw.textbbox((0, 0), hook, font=hf)
            self._outlined_text(draw, ((w - bbox_h[2] + bbox_h[0]) // 2, h // 2 - 30),
                                hook, hf, (255, 224, 0), outline_w=4)
        if 0.55 < pp < 0.59 and alive > 10:
            hf = self._font(32)
            hook = "QUIEN SOBREVIVE?"
            bbox_h = draw.textbbox((0, 0), hook, font=hf)
            self._outlined_text(draw, ((w - bbox_h[2] + bbox_h[0]) // 2, h // 2 - 30),
                                hook, hf, (255, 150, 50), outline_w=4)
        if 0.78 < pp < 0.82 and alive > 3:
            hf = self._font(36)
            hook = "FINAL SHOWDOWN!"
            bbox_h = draw.textbbox((0, 0), hook, font=hf)
            self._outlined_text(draw, ((w - bbox_h[2] + bbox_h[0]) // 2, h // 2 - 30),
                                hook, hf, (255, 50, 50), outline_w=4)

        # Subscribe button
        if frame % 350 < 160 and phase == "racing":
            sf = self._font(20)
            st = "> SUBSCRIBE <<"
            bbox_s = draw.textbbox((0, 0), st, font=sf)
            tw_s = bbox_s[2] - bbox_s[0]
            sx = (w - tw_s) // 2
            sy = h - 78
            draw.rounded_rectangle([sx - 8, sy - 4, sx + tw_s + 8, sy + 26],
                                   radius=8, fill=(220, 0, 0))
            draw.text((sx, sy), st, font=sf, fill=(255, 255, 255))

        # Milestone alerts
        if alive == 10:
            af = self._font(38)
            at = "** TOP 10! **"
            bbox_a = draw.textbbox((0, 0), at, font=af)
            self._outlined_text(draw, ((w - bbox_a[2] + bbox_a[0]) // 2, 140),
                                at, af, (255, 100, 50), outline_w=4)
        if alive == 5:
            af = self._font(42)
            at = "** FINAL 5! **"
            bbox_a = draw.textbbox((0, 0), at, font=af)
            self._outlined_text(draw, ((w - bbox_a[2] + bbox_a[0]) // 2, 140),
                                at, af, (255, 50, 255), outline_w=4)
        if alive == 2:
            af = self._font(46)
            at = "** 1v1 FINAL! **"
            bbox_a = draw.textbbox((0, 0), at, font=af)
            self._outlined_text(draw, ((w - bbox_a[2] + bbox_a[0]) // 2, 140),
                                at, af, (255, 0, 0), outline_w=5)

    # ══════════════════════════════════════════════════════════════════════════
    # COUNTDOWN
    # ══════════════════════════════════════════════════════════════════════════
    def _render_countdown(self, draw: ImageDraw.Draw, t: float):
        w, h = self.w, self.h
        if t < 1.0:
            txt, col = "3", (255, 100, 100)
        elif t < 2.0:
            txt, col = "2", (255, 200, 100)
        elif t < 3.0:
            txt, col = "1", (100, 255, 100)
        else:
            txt, col = "GO!", (50, 255, 50)

        sub_t = t % 1.0
        scale = 1.0 + 0.4 * (1.0 - sub_t)
        fs = int(140 * scale)
        f = self._font(fs)
        bbox = draw.textbbox((0, 0), txt, font=f)
        tw, th_t = bbox[2] - bbox[0], bbox[3] - bbox[1]
        self._outlined_text(draw, ((w - tw) // 2, (h - th_t) // 2 - 120),
                            txt, f, col, outline_w=5)

        sf = self._font(28)
        st = "100 BRAINROT BALLS - 1 SURVIVES"
        bbox_s = draw.textbbox((0, 0), st, font=sf)
        self._outlined_text(draw, ((w - bbox_s[2] + bbox_s[0]) // 2, h // 2 + 40),
                            st, sf, (255, 255, 255), outline_w=3)

        sf2 = self._font(20)
        st2 = "7 RANDOM CHALLENGES THIS ROUND"
        bbox_s2 = draw.textbbox((0, 0), st2, font=sf2)
        self._outlined_text(draw, ((w - bbox_s2[2] + bbox_s2[0]) // 2, h // 2 + 82),
                            st2, sf2, (255, 200, 100), outline_w=2)

    # ══════════════════════════════════════════════════════════════════════════
    # WINNER SCREEN
    # ══════════════════════════════════════════════════════════════════════════
    def _render_winner_screen(self, img: Image.Image, draw: ImageDraw.Draw,
                               winner: Ball, t: float, frame: int) -> Image.Image:
        w, h = self.w, self.h

        # Dark overlay
        overlay = Image.new("RGBA", (w, h), (0, 0, 0, 140))
        img = img.convert("RGBA")
        img = Image.alpha_composite(img, overlay)
        img = img.convert("RGB")
        draw = ImageDraw.Draw(img)

        # Rainbow border
        hue_w = (frame * 0.03) % 1.0
        rc, gc, bc = [int(c * 255) for c in colorsys.hsv_to_rgb(hue_w, 1.0, 1.0)]
        draw.rectangle([0, 0, w, h], outline=(rc, gc, bc), width=8)

        # Confetti
        conf_rng = random.Random(42)
        for _ in range(100):
            cx_c = conf_rng.randint(0, w)
            cy_c = (conf_rng.randint(0, h) + frame * 3) % h
            cs = conf_rng.randint(5, 16)
            cc = (conf_rng.randint(100, 255), conf_rng.randint(100, 255),
                  conf_rng.randint(100, 255))
            if conf_rng.random() < 0.5:
                draw.rectangle([cx_c, cy_c, cx_c + cs, cy_c + cs // 2], fill=cc)
            else:
                draw.ellipse([cx_c, cy_c, cx_c + cs, cy_c + cs], fill=cc)

        # "WINNER" text
        wf = self._font(72)
        wt = "★ WINNER! ★"
        bbox_w = draw.textbbox((0, 0), wt, font=wf)
        tw_w = bbox_w[2] - bbox_w[0]
        self._outlined_text(draw, ((w - tw_w) // 2, h // 4 - 20),
                            wt, wf, (255, 220, 50), outline_w=5)

        # Big winner ball
        big_r = 60
        cx_w = w // 2
        cy_w = h // 2
        bounce = int(abs(math.sin(frame * 0.15)) * 25)
        cy_w -= bounce

        # Glow rings
        for gr_i in range(big_r + 35, big_r, -3):
            draw.ellipse([cx_w - gr_i, cy_w - gr_i, cx_w + gr_i, cy_w + gr_i],
                         fill=winner.color)

        draw.ellipse([cx_w - big_r, cy_w - big_r, cx_w + big_r, cy_w + big_r],
                     fill=winner.color, outline=(255, 255, 255), width=4)

        # Winner character image
        char_img = self._character_images.get(winner.name)
        if char_img is not None:
            icon_big = char_img.resize((big_r, big_r), Image.LANCZOS)
            mask = Image.new("L", (big_r, big_r), 0)
            mask_draw = ImageDraw.Draw(mask)
            mask_draw.ellipse([0, 0, big_r - 1, big_r - 1], fill=255)
            px_w = cx_w - big_r // 2
            py_w = cy_w - big_r // 2
            try:
                img.paste(icon_big, (px_w, py_w), mask)
            except Exception:
                pass
        draw = ImageDraw.Draw(img)

        # Winner name
        nf = self._font(40)
        nt = f"[ {winner.name} ]"
        bbox_n = draw.textbbox((0, 0), nt, font=nf)
        tw_n = bbox_n[2] - bbox_n[0]
        self._outlined_text(draw, ((w - tw_n) // 2, cy_w + big_r + 35),
                            nt, nf, winner.color, outline_w=4)

        # Subtitle
        sf = self._font(28)
        st = "** LAST BALL STANDING! **"
        bbox_s = draw.textbbox((0, 0), st, font=sf)
        tw_s = bbox_s[2] - bbox_s[0]
        self._outlined_text(draw, ((w - tw_s) // 2, cy_w + big_r + 85),
                            st, sf, (255, 255, 255), outline_w=3)

        # Engagement hooks
        hf = self._font(24)
        ht1 = "Did you guess right? Comment below!"
        bbox_h1 = draw.textbbox((0, 0), ht1, font=hf)
        self._outlined_text(draw, ((w - bbox_h1[2] + bbox_h1[0]) // 2, h - 170),
                            ht1, hf, (255, 200, 100), outline_w=3)

        hf2 = self._font(22)
        ht2 = "Adivinaste? Comenta tu favorito!"
        bbox_h2 = draw.textbbox((0, 0), ht2, font=hf2)
        self._outlined_text(draw, ((w - bbox_h2[2] + bbox_h2[0]) // 2, h - 140),
                            ht2, hf2, (255, 180, 80), outline_w=2)

        return img

print("✅ Renderer ready.")


